# Pin this repo to the public npm registry, overriding any user/global ~/.npmrc
# (e.g. a corporate Artifactory). This keeps package-lock.json `resolved` URLs on
# registry.npmjs.org so `npm ci` works on GitHub CI runners with no private creds.
# (CI E401 fix — 2026-06-19.)
registry=https://registry.npmjs.org/
