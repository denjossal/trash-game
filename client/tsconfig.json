{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "composite": false
  },
  "references": [{ "path": "../shared" }],
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
